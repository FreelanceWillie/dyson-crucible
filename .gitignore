# --- Python environment ---
.venv/
__pycache__/
*.pyc

# --- Model caches / weights (large, never commit) ---
.cache/
models/
*.safetensors
*.bin
*.ckpt

# --- Generated output ---
outputs/**
outputs/_jobs.json
vectors/*.svg

# --- Generated brief content (keep folder markers only) ---
briefs/*/

# --- User reference images (keep README + folder markers only) ---
references/**/*
!references/README.txt
!references/.gitkeep
!references/**/.gitkeep

# --- Keep folder markers ---
!.gitkeep

# --- Per-machine config (generated from config.example.yaml on first run) ---
config.yaml

# --- Per-project data workspaces (created at runtime) ---
projects/

# --- Your own model additions (never tracked; see checkpoints_local.example.json) ---
checkpoints_local.json
